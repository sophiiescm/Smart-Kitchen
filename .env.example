# Kopiere diese Datei zu .env und passe die Werte an.
# NIEMALS .env ins Git einchecken!

# ──────────────────────────────────────────────
# MySQL – Datenbank
# ──────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=smart_kitchen

# Dedizierter App-Benutzer
MYSQL_USER=appuser
MYSQL_PASSWORD=change-me-app-password

# Host & Port (innerhalb von Docker immer "db" / 3306)
MYSQL_HOST=db
MYSQL_PORT=3306

# ──────────────────────────────────────────────
# Backend – Datenbankverbindung
# ──────────────────────────────────────────────
# Optional: Wenn du eine komplette DB-URL verwenden möchtest,
# kannst du sie hier setzen. Docker Compose schreibt ansonsten
# automatisch eine passende URL basierend auf MYSQL_* Werten.
DATABASE_URL=mysql+pymysql://${MYSQL_USER}:${MYSQL_PASSWORD}@db:3306/${MYSQL_DATABASE}

# ──────────────────────────────────────────────
# Backend – JWT Authentifizierung
# ──────────────────────────────────────────────
# Sicheren Key generieren: openssl rand -hex 32
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
