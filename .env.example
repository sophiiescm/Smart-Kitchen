# Copy this to .env and fill in secrets before running docker-compose
# Do NOT commit your .env with real secrets.

# MySQL
MYSQL_ROOT_PASSWORD=your_mysql_root_password
MYSQL_DATABASE=app_db
MYSQL_USER=appuser
MYSQL_PASSWORD=appsecret123
MYSQL_HOST=db
MYSQL_PORT=3306

# Application
SECRET_KEY=change-me-in-production

# Optional: override compose DATABASE_URL
# DATABASE_URL=mysql+pymysql://appuser:appsecret123@db:3306/app_db
