
<script lang="ts">
  // Später: Daten vom Backend per +page.server.ts laden
  // Fürs Erste: Mock-Daten

  type Recipe = {
    id: number;
    title: string;
    description: string;
    category: string;
    rating: number;
    ratingCount: number;
    author: string;
    timeMinutes: number;
    emoji: string;
    isPublic: boolean;
  };

  const allRecipes: Recipe[] = [
    { id: 1, title: 'Spaghetti Carbonara', description: 'Cremige Pasta mit knusprigem Speck und Parmesan.', category: 'Pasta', rating: 4.8, ratingCount: 124, author: 'Maria K.', timeMinutes: 25, emoji: '🍝', isPublic: true },
    { id: 2, title: 'Avocado Toast', description: 'Knuspriges Sauerteigbrot mit cremiger Avocado und Chili.', category: 'Frühstück', rating: 4.5, ratingCount: 87, author: 'Jonas M.', timeMinutes: 10, emoji: '🥑', isPublic: true },
    { id: 3, title: 'Kürbissuppe', description: 'Samtiger Hokkaido-Kürbis mit Ingwer und Kokosmilch.', category: 'Suppe', rating: 4.7, ratingCount: 63, author: 'Sara L.', timeMinutes: 40, emoji: '🎃', isPublic: true },
    { id: 4, title: 'Schokoladenkuchen', description: 'Saftig und intensiv — mit flüssigem Kern.', category: 'Dessert', rating: 4.9, ratingCount: 201, author: 'Tom R.', timeMinutes: 55, emoji: '🍫', isPublic: true },
    { id: 5, title: 'Caesar Salad', description: 'Knackiger Römersalat mit hausgemachtem Dressing.', category: 'Salat', rating: 4.3, ratingCount: 45, author: 'Lena W.', timeMinutes: 20, emoji: '🥗', isPublic: true },
    { id: 6, title: 'Shakshuka', description: 'Eier in würziger Tomatensauce mit Paprika und Feta.', category: 'Frühstück', rating: 4.6, ratingCount: 92, author: 'Ali H.', timeMinutes: 30, emoji: '🍳', isPublic: true },
    { id: 7, title: 'Beef Burger', description: 'Saftiges Rindfleisch-Patty mit Cheddar und karamellisierten Zwiebeln.', category: 'Hauptgericht', rating: 4.7, ratingCount: 158, author: 'Max B.', timeMinutes: 35, emoji: '🍔', isPublic: true },
    { id: 8, title: 'Tiramisu', description: 'Klassisches italienisches Dessert mit Mascarpone und Espresso.', category: 'Dessert', rating: 4.8, ratingCount: 112, author: 'Sofia R.', timeMinutes: 30, emoji: '☕', isPublic: true },
    { id: 9, title: 'Ramen', description: 'Japanische Nudelsuppe mit reichhaltigem Tonkotsu-Brühe.', category: 'Suppe', rating: 4.9, ratingCount: 76, author: 'Kenji T.', timeMinutes: 90, emoji: '🍜', isPublic: true },
  ];

  const categories = ['Alle', 'Pasta', 'Frühstück', 'Suppe', 'Dessert', 'Salat', 'Hauptgericht'];
  const sortOptions = [
    { value: 'rating', label: 'Beste Bewertung' },
    { value: 'time', label: 'Schnellste zuerst' },
    { value: 'popular', label: 'Beliebteste' },
  ];

  let selectedCategory = $state('Alle');
  let searchTerm = $state('');
  let sortBy = $state('rating');
  let viewMode = $state<'grid' | 'list'>('grid');

  let filteredRecipes = $derived(() => {
    let result = allRecipes.filter((r) => {
      const matchCat = selectedCategory === 'Alle' || r.category === selectedCategory;
      const matchSearch = searchTerm === '' ||
        r.title.toLowerCase().includes(searchTerm.toLowerCase()) ||
        r.description.toLowerCase().includes(searchTerm.toLowerCase());
      return matchCat && matchSearch;
    });

    if (sortBy === 'rating') result = [...result].sort((a, b) => b.rating - a.rating);
    else if (sortBy === 'time') result = [...result].sort((a, b) => a.timeMinutes - b.timeMinutes);
    else if (sortBy === 'popular') result = [...result].sort((a, b) => b.ratingCount - a.ratingCount);

    return result;
  });

  function renderStars(rating: number) {
    return '★'.repeat(Math.round(rating)) + '☆'.repeat(5 - Math.round(rating));
  }
</script>

<div class="page">

  <!-- Seiten-Header -->
  <div class="page-header">
    <div class="container">
      <h1>Alle Rezepte</h1>
      <p>{allRecipes.length} Rezepte in der Sammlung</p>
    </div>
  </div>

  <div class="container">

    <!-- Suche + Sortierung + Ansicht -->
    <div class="toolbar">
      <div class="search-bar">
        <span>🔍</span>
        <input type="text" placeholder="Rezept oder Zutat suchen…" bind:value={searchTerm} />
        {#if searchTerm}
          <button class="clear-btn" onclick={() => searchTerm = ''}>✕</button>
        {/if}
      </div>

      <div class="toolbar-right">
        <select bind:value={sortBy}>
          {#each sortOptions as opt}
            <option value={opt.value}>{opt.label}</option>
          {/each}
        </select>

        <div class="view-toggle">
          <button class:active={viewMode === 'grid'} onclick={() => viewMode = 'grid'} title="Kachelansicht">⊞</button>
          <button class:active={viewMode === 'list'} onclick={() => viewMode = 'list'} title="Listenansicht">☰</button>
        </div>
      </div>
    </div>

    <!-- Kategoriefilter -->
    <div class="filters">
      {#each categories as cat}
        <button
          class="filter-btn"
          class:selected={selectedCategory === cat}
          onclick={() => selectedCategory = cat}
        >
          {cat}
        </button>
      {/each}
    </div>

    <p class="results-count">{filteredRecipes().length} Ergebnisse</p>

    <!-- Rezeptliste -->
    {#if filteredRecipes().length > 0}
      <div class="recipes" class:grid={viewMode === 'grid'} class:list={viewMode === 'list'}>
        {#each filteredRecipes() as recipe (recipe.id)}
          <a href="/recipes/{recipe.id}" class="recipe-card" class:card-list={viewMode === 'list'}>

            <div class="card-image" class:image-list={viewMode === 'list'}>
              <span class="card-emoji">{recipe.emoji}</span>
              <span class="card-category">{recipe.category}</span>
            </div>

            <div class="card-body">
              <h2>{recipe.title}</h2>
              <p class="desc">{recipe.description}</p>
              <div class="meta">
                <span class="stars">{renderStars(recipe.rating)}</span>
                <span class="rating-text">{recipe.rating} ({recipe.ratingCount})</span>
                <span class="dot">·</span>
                <span>⏱ {recipe.timeMinutes} Min.</span>
                <span class="dot">·</span>
                <span>von {recipe.author}</span>
              </div>
            </div>
          </a>
        {/each}
      </div>
    {:else}
      <div class="empty">
        <p>😕 Keine Rezepte gefunden.</p>
        <button onclick={() => { searchTerm = ''; selectedCategory = 'Alle'; }}>
          Filter zurücksetzen
        </button>
      </div>
    {/if}

  </div>
</div>

