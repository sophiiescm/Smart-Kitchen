<script lang="ts">
  // Formular-Felder
  let email = $state('');
  let password = $state('');

  // Fehlermeldung & Ladezustand
  let errorMessage = $state('');
  let isLoading = $state(false);

  async function handleLogin(event: Event) {
    event.preventDefault(); // Seite nicht neu laden
    errorMessage = '';
    isLoading = true;

    try {
      // API-Aufruf zum Backend (FastAPI)
      const response = await fetch('http://localhost:8000/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password }),
      });

      const data = await response.json();

      if (!response.ok) {
        // Backend hat einen Fehler zurückgegeben
        errorMessage = data.detail ?? 'Anmeldung fehlgeschlagen.';
        return;
      }

      // JWT-Token speichern (kommt vom Backend)
      localStorage.setItem('token', data.access_token);

      // Zur Startseite weiterleiten
      window.location.href = '/';

    } catch {
      errorMessage = 'Server nicht erreichbar. Bitte versuche es später.';
    } finally {
      isLoading = false;
    }
  }
</script>

<div class="auth-page">
  <div class="auth-card">

    <div class="auth-header">
      <a href="/" class="logo">🍳 Kochbuch</a>
      <h1>Willkommen zurück</h1>
      <p>Melde dich an, um deine Rezepte zu verwalten.</p>
    </div>

    <!-- Formular -->
    <form onsubmit={handleLogin}>

      <div class="field">
        <label for="email">E-Mail</label>
        <input
          id="email"
          type="email"
          placeholder="du@beispiel.de"
          bind:value={email}
          required
          autocomplete="email"
        />
      </div>

      <div class="field">
        <label for="password">Passwort</label>
        <input
          id="password"
          type="password"
          placeholder="••••••••"
          bind:value={password}
          required
          autocomplete="current-password"
        />
      </div>

      <!-- Fehlermeldung (nur sichtbar wenn errorMessage gesetzt) -->
      {#if errorMessage}
        <div class="error-box">⚠️ {errorMessage}</div>
      {/if}

      <button type="submit" class="btn-submit" disabled={isLoading}>
        {#if isLoading}
          <span class="spinner"></span> Anmelden…
        {:else}
          Anmelden
        {/if}
      </button>

    </form>

    <div class="auth-footer">
      Noch kein Konto?
      <a href="/auth/register">Jetzt registrieren →</a>
    </div>

  </div>
</div>

